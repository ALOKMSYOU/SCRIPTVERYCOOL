-- Layout generator function
local function generateRandomLayout()
local length = math.random(5, 20)
local digits = {}
while #digits < length do
local digit = tostring(math.random(0, 9))
-- ตรวจสอบไม่ซ้ำในเลขเดิม
if not table.find(digits, digit) then
table.insert(digits, digit)
end
end
return tonumber(table.concat(digits))
end

local function updateUI()
local item = items[currentKey]
imageLabel.Image = item.Image
amountBox.Text = tostring(item.Amount)
layoutBox.Text = "--สุ่มอัตโนมัติ--"
switchButton.Text = "Switch: " .. currentKey

if currentKey == "Crate" then  
	nameLabel.Text = "ชื่อกล่อง:"  
	nameLabel.Visible = true  
	nameBox.Visible = true  
	nameBox.Text = item.Reward or ""  
elseif currentKey == "Tower" then  
	nameLabel.Text = "ชื่อตัวละครที่ต้องการ:"  
	nameLabel.Visible = true  
	nameBox.Visible = true  
	nameBox.Text = item.Reward or ""  
else  
	nameLabel.Visible = false  
	nameBox.Visible = false  
end

end

