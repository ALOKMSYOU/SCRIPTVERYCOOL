currentIndex += 1
if currentIndex > #keys then currentIndex = 1 end
currentKey = keys[currentIndex]
updateUI()
end)

confirmButton.MouseButton1Click:Connect(function()
local amt = tonumber(amountBox.Text)
if not amt then
warn("กรุณาใส่จำนวนเป็นตัวเลข")
return
end

local lay = generateRandomLayout()  
local item = items[currentKey]  
